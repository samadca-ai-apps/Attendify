// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: schools
// Document ID: schoolId
// Fields:
//   - schoolId: string (required, immutable)
//   - name: string (required)
//   - address: string
//   - contactPerson: string
//   - schoolCode: string (required)
//   - email: string
//   - createdAt: timestamp (required)
//
// Collection: users
// Document ID: uid
// Fields:
//   - uid: string (required, immutable)
//   - schoolId: string (required, immutable)
//   - role: string (required, enum: ['admin', 'it_coordinator', 'teacher'])
//   - name: string (required)
//   - teacherId: string (required)
//   - status: string (required, enum: ['active', 'inactive'])
//   - firstLogin: bool (required)
//
// Collection: classes
// Document ID: classId
// Fields:
//   - classId: string (required, immutable)
//   - schoolId: string (required, immutable)
//   - name: string (required)
//
// Collection: divisions
// Document ID: divisionId
// Fields:
//   - divisionId: string (required, immutable)
//   - schoolId: string (required, immutable)
//   - classId: string (required, immutable)
//   - name: string (required)
//   - teacherId: string (optional)
//
// Collection: students
// Document ID: studentId
// Fields:
//   - studentId: string (required, immutable)
//   - schoolId: string (required, immutable)
//   - classId: string (required, immutable)
//   - divisionId: string (required, immutable)
//   - name: string (required)
//   - admissionNumber: string (required)
//   - status: string (required, enum: ['active', 'pass-out'])
//
// Collection: attendance
// Document ID: attendanceId
// Fields:
//   - attendanceId: string (required, immutable)
//   - schoolId: string (required, immutable)
//   - classId: string (required, immutable)
//   - divisionId: string (required, immutable)
//   - date: string (required, YYYY-MM-DD)
//   - records: list (required, items: {studentId, status, note})
//     - status: enum: ['full_day', 'fn_only', 'an_only', 'absent']
//   - submittedBy: string (required, immutable)
//   - timestamp: timestamp (required)
//
// Collection: holidays
// Document ID: holidayId
// Fields:
//   - holidayId: string (required, immutable)
//   - schoolId: string (required, immutable)
//   - date: string (required, format: YYYY-MM-DD)
//   - type: string (required, enum: ['holiday', 'working_saturday'])
//   - reason: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isSchoolMember(schoolId) {
      return isAuthenticated() && 
             (isSuperAdmin() || 
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId)
             );
    }

    function hasRole(role) {
      return isAuthenticated() && 
             (isSuperAdmin() || (
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role
             ));
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "samadca@gmail.com" || 
              request.auth.token.email == "9544120869@attendify.com" ||
              (request.auth.token.email != null && (request.auth.token.email.matches(".*samadca@gmail.com.*") || request.auth.token.email.matches(".*9544120869@attendify.com.*"))));
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole('admin');
    }

    function isITCoordinator() {
      return hasRole('it_coordinator');
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isStaff() {
      return isAdmin() || isITCoordinator();
    }

    function isNotFutureDate(dateStr) {
      // dateStr is YYYY-MM-DD. CEL does not support split().
      // We use timestamp conversion with a 24h buffer to account for timezone differences.
      // This ensures that "today" in any timezone is not considered a future date relative to UTC.
      return timestamp(dateStr + "T00:00:00Z") <= request.time + duration.value(24, 'h');
    }

    function isValidSchool(data) {
      return data.schoolId is string && data.schoolId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.schoolCode is string && data.schoolCode.size() >= 4 &&
             data.createdAt is string;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.schoolId is string && data.schoolId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.teacherId is string && data.teacherId.size() >= 1 &&
             data.role in ['admin', 'it_coordinator', 'teacher'] &&
             data.status in ['active', 'inactive'] &&
             data.firstLogin is bool;
    }

    function isValidClass(data) {
      return data.classId is string && data.classId.size() > 0 &&
             data.schoolId is string && data.schoolId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50;
    }

    function isValidDivision(data) {
      return data.divisionId is string && data.divisionId.size() > 0 &&
             data.schoolId is string && data.schoolId.size() > 0 &&
             data.classId is string && data.classId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50;
    }

    function isValidStudent(data) {
      return data.studentId is string && data.studentId.size() > 0 &&
             data.schoolId is string && data.schoolId.size() > 0 &&
             data.classId is string && data.classId.size() > 0 &&
             data.divisionId is string && data.divisionId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.admissionNumber is string && data.admissionNumber.size() > 0 &&
             data.status in ['active', 'pass-out', 'terminated'] &&
             (!('admissionDate' in data) || (data.admissionDate is string && data.admissionDate.matches("^[0-9]{4}-[0-9]{2}-[0-9]{2}$"))) &&
             (!('classHistory' in data) || data.classHistory is list);
    }

    function isValidAttendance(data) {
      return data.attendanceId is string && data.attendanceId.size() > 0 &&
             data.schoolId is string && data.schoolId.size() > 0 &&
             data.classId is string && data.classId.size() > 0 &&
             data.divisionId is string && data.divisionId.size() > 0 &&
             data.date is string && data.date.matches("^[0-9]{4}-[0-9]{2}-[0-9]{2}$") &&
             isNotFutureDate(data.date) &&
             data.records is list && data.records.size() > 0 &&
             data.submittedBy is string &&
             data.timestamp is string;
    }

    function isValidHoliday(data) {
      return data.holidayId is string && data.holidayId.size() > 0 &&
             data.schoolId is string && data.schoolId.size() > 0 &&
             data.date is string && data.date.matches("^[0-9]{4}-[0-9]{2}-[0-9]{2}$") &&
             data.type in ['holiday', 'working_saturday'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Schools
    match /schools/{schoolId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        isSchoolMember(schoolId)
      );
      allow create: if isAuthenticated() && isValidSchool(request.resource.data); 
      allow update: if isAuthenticated() && isSchoolMember(schoolId) && isAdmin();
      allow delete: if false;
    }

    // Users
    match /users/{uid} {
      allow read: if isAuthenticated() && (
        request.auth.uid == uid || 
        isSuperAdmin() ||
        (resource != null && isSchoolMember(resource.data.schoolId) && isStaff())
      );
      allow create: if isAuthenticated() && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        (request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'schoolId', 'role'])) ||
        (resource != null && isSchoolMember(resource.data.schoolId) && isStaff())
      );
      allow delete: if isAuthenticated() && resource != null && isSchoolMember(resource.data.schoolId) && isAdmin();
    }

    // Classes
    match /classes/{classId} {
      allow read: if isAuthenticated() && isSchoolMember(resource.data.schoolId);
      allow create: if isAuthenticated() && isSchoolMember(request.resource.data.schoolId) && isStaff() && isValidClass(request.resource.data);
      allow update: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff() && isValidClass(request.resource.data);
      allow delete: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
    }

    // Divisions
    match /divisions/{divisionId} {
      allow read: if isAuthenticated() && isSchoolMember(resource.data.schoolId);
      allow create: if isAuthenticated() && isSchoolMember(request.resource.data.schoolId) && isStaff() && isValidDivision(request.resource.data);
      allow update: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff() && isValidDivision(request.resource.data);
      allow delete: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
    }

    // Students
    match /students/{studentId} {
      allow read: if isAuthenticated() && isSchoolMember(resource.data.schoolId);
      allow create: if isAuthenticated() && isSchoolMember(request.resource.data.schoolId) && isStaff() && isValidStudent(request.resource.data);
      allow update: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff() && isValidStudent(request.resource.data);
      allow delete: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && isSchoolMember(resource.data.schoolId);
      allow create: if isAuthenticated() && 
                      request.resource.data.submittedBy == request.auth.uid;
      allow update: if isAuthenticated() && 
                      (isTeacher() || isStaff());
      allow delete: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
    }

    // Holidays
    match /holidays/{holidayId} {
      allow read: if isAuthenticated() && isSchoolMember(resource.data.schoolId);
      allow create: if isAuthenticated() && isSchoolMember(request.resource.data.schoolId) && isStaff() && isValidHoliday(request.resource.data);
      allow update: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff() && isValidHoliday(request.resource.data);
      allow delete: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
    }

    // AcademicYearConfigs
    match /academicYearConfigs/{configId} {
      allow read: if isAuthenticated() && isSchoolMember(resource.data.schoolId);
      allow create: if isAuthenticated() && isSchoolMember(request.resource.data.schoolId) && isStaff();
      allow update: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
      allow delete: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
    }

    // Academic Years
    match /academicYears/{yearId} {
      allow read: if isAuthenticated() && isSchoolMember(resource.data.schoolId);
      allow create: if isAuthenticated() && isSchoolMember(request.resource.data.schoolId) && isStaff();
      allow update: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
      allow delete: if isAuthenticated() && isSchoolMember(resource.data.schoolId) && isStaff();
    }

    // Dashboard Static Stats
    match /dashboard_static_stats/{statId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSchoolMember(resource.data.schoolId));
      allow create, update, delete: if isSuperAdmin();
    }
  }
}
